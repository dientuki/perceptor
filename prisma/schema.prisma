generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum JobStatus {
  CREATED
  SEARCHING
  STALLED
  DOWNLOADING
  PAUSED
  QUEUED
  ENCODING
  COMPLETED
  ERROR
}

enum DownloadStatus {
  CREATED        // Job creado en el sistema
  SEARCHING      // Buscando torrent en tracker
  ADDED          // Torrent agregado al cliente
  DOWNLOADING    // Descargando activamente
  PAUSED         // Pausado en cliente
  COMPLETED      // Descarga finalizada
  ERROR          // Error en cualquier punto
}

enum EncodeStatus {
  WAITING
  QUEUED
  ENCODING
  COMPLETED
  ERROR
}

enum MediaType {
  MOVIE
  TV
}

model Movie {
  id               Int       @id @default(autoincrement())
  tmdbId           Int       @unique
  title            String
  overview         String?
  posterUrl        String?
  status      String?
  releaseDate      DateTime?
  originalLanguage String
  isLiveAction Boolean @default(true)

  job          Job?
  jobStatus        JobStatus? @default(CREATED)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("movies")
}

model Job {
  id        Int      @id @default(autoincrement())
  tmdbId    Int      // TMDB ID of the Show or Movie
  movieId   Int?     @unique
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  episodeId Int?     @unique
  episode   Episode? @relation(fields: [episodeId], references: [id])
  infoHash  String?
  
  mediaType MediaType @default(MOVIE)
  downloadStatus  DownloadStatus @default(CREATED)
  encodeStatus    EncodeStatus   @default(WAITING)

  ffmpegCommand String?

  errorMessage    String?
  root_path   String? // Ruta al archivo descargado o al resultado del encode
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tmdbId, mediaType, episodeId], name: "tmdbId_mediaType_episodeId")
  @@map("jobs")
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("settings")
}

model Language {
  id   Int    @id @default(autoincrement())
  iso2 String @unique
  iso3 String

  @@map("languages")
}

model Show {
  id          Int       @id @default(autoincrement())
  tmdbId      Int       @unique
  title       String
  overview    String?
  posterUrl   String?
  status      String?
  isLiveAction Boolean @default(true)
  originalLanguage String
  releaseDate DateTime?
  
  seasons     Season[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("shows")
}

model Season {
  id           Int       @id @default(autoincrement())
  showId       Int
  show         Show      @relation(fields: [showId], references: [id], onDelete: Cascade)
  seasonNumber Int
  releaseDate  DateTime?
  
  episodes     Episode[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([showId, seasonNumber])
  @@map("seasons")
}

model Episode {
  id           Int       @id @default(autoincrement())
  seasonId     Int
  season       Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  episodeNumber Int
  title        String?
  overview     String?
  releaseDate  DateTime?
  filePath     String?
  job          Job?

  jobStatus        JobStatus @default(CREATED)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([seasonId, episodeNumber])
  @@map("episodes")
}
